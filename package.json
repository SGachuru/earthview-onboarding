{
  "name": "earthview-onboarding-backend",
  "version": "1.0.0",
  "description": "Backend for EarthView onboarding",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:mock": "cross-env USE_MOCK_DB=true nodemon server.js",
    "build:frontend": "cd frontend && npm run build",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "start:full": "npm run build:frontend && npm run start:prod",
    "start:mock": "cross-env USE_MOCK_DB=true node server.js",
    "dev:full": "concurrently \"npm run dev --prefix frontend\" \"nodemon server.js\"",
    "dev:full:mock": "concurrently \"npm run dev --prefix frontend\" \"npm run dev:mock\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.0"
  }
}
